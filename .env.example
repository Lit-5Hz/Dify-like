# Local env
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dify_like
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
DOCUMENT_INLINE_INGEST=true
STORAGE_DIR=./storage
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

KNOWLEDGE_EMBEDDING_PROVIDER=
KNOWLEDGE_EMBEDDING_MODEL=
KNOWLEDGE_EMBEDDING_DIMENSION=
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_BASE_URL=

RETRIEVAL_JINA_API_KEY=
RETRIEVAL_JINA_MODEL=jina-reranker-v2
RETRIEVAL_JINA_BASE_URL=https://api.jina.ai/v1

DOCUMENT_UNSTRUCTURED_API_URL=
DOCUMENT_UNSTRUCTURED_API_KEY=
DOCUMENT_MINERU_API_URL=
DOCUMENT_MINERU_API_KEY=

# Independent platform assistant model.
# This is intentionally separate from workflow agent node model credentials.
# Use an OpenAI-compatible chat completions endpoint base URL, for example:
#   https://api.openai.com/v1
#   https://api.deepseek.com/v1
#   https://dashscope.aliyuncs.com/compatible-mode/v1
PLATFORM_ASSISTANT_API_BASE_URL=
PLATFORM_ASSISTANT_API_KEY=
PLATFORM_ASSISTANT_MODEL=
PLATFORM_ASSISTANT_TEMPERATURE=0.2
PLATFORM_ASSISTANT_TIMEOUT_SECONDS=30

AGENTSCOPE_TRACING_URL=http://localhost:4318/v1/traces
AGENTSCOPE_TRACING_SERVICE_NAME=dify-like-agent-runtime
